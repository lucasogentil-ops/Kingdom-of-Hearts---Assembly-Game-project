00003790  0642 002B               1035      ADD.W   #43,D2
00003794  33C2 00004EBA           1036      MOVE.W  D2,RNG_SEED
0000379A                          1037  
0000379A                          1038      ;take low byte and mod100
0000379A  0242 00FF               1039      ANDI.W  #$00FF,D2
0000379E  3202                    1040      MOVE.W  D2,D1
